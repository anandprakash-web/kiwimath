  "params": {
    "name":   {"inherit_from_parent": true},
    "object": {"inherit_from_parent": true},
    "N":      {"inherit_from_parent": true}
  },
  "derived": {
    "pronoun_subject": "pronoun_from_name(name)"
  },

  "answer_formula": "N - 1",
  "distractors": [
    {"formula": "N",     "label": "no_change"},
    {"formula": "N + 1", "label": "added_one"},
    {"formula": "N - 2", "label": "overcorrect"}
  ],


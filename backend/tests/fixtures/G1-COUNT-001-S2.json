  "answer_formula": "N - K_small",
  "distractors": [
    {"formula": "N",                "label": "no_change"},
    {"formula": "K_small",          "label": "picked_crossed_out"},
    {"formula": "N - K_small + 1", "label": "off_by_one"}
  ],


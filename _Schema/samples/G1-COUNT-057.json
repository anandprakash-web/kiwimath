      "range": [
        3,
        6
      ]
    },
    "D": {
      "range": [
        3,
        5
      ]
    },
    "colour": {
      "pool": [
        "red",
        "blue",
        "green",
        "yellow"
      ]
    },
    "other_colour": {
      "pool": [
        "grey",
        "white",
        "brown"
      ]
    },
    "object": {
      "pool": [
        "buttons",
        "beads",
        "balloons",
        "blocks"
      ]
    }
  },
  "derived": {
    "target_objects": "colour + object"
  },
  "answer_formula": "N",
  "distractors": [
    {
      "formula": "N + D",
      "label": "counted_all"
    },
    {
      "formula": "D",
      "label": "counted_wrong_colour"
    },
    {
      "formula": "N + 1",
      "label": "over_count"
    }
  ],
  "misconceptions": [
    {
      "trigger_answer": "N + D",
      "diagnosis": "counted_all_colours",
      "feedback_child": "You counted ALL the {object}! We only want the {colour} ones.",
      "step_down_path": [
        "G1-COUNT-057-S1"
      ]
    },
    {
      "trigger_answer": "D",
      "diagnosis": "counted_wrong_colour",
      "feedback_child": "Those are the {other_colour} ones! Look for the {colour} {object}.",
      "step_down_path": [
        "G1-COUNT-057-S1"
      ]
    },
    {
      "trigger_answer": "N + 1",
      "diagnosis": "included_one_wrong_colour",
      "feedback_child": "One of those isn't {colour}! Check each one's colour carefully.",
      "step_down_path": [
        "G1-COUNT-057-S1"
      ]
    }
  ],
  "socratic_feedback": {
    "on_correct": "You found all {N} {colour} ones! Great at spotting colours!",

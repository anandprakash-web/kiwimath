  "visual": null,
  "visual_manifest": {
    "art_brief": "A mix of {object} in different colours scattered on a white surface. {N} of them are {colour}. The rest ({D} of them) are {other_colour}. The {colour} ones should be clearly distinguishable.",
    "alt_text": "{N} {colour} {object} and {D} {other_colour} {object}.",
    "style": "warm_cartoon",
    "layout_hint": "scattered",
    "visual_type": "illustration"
  },
  "params": {

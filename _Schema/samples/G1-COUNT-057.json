  "pedagogy": "cpa_concrete",
  "stem_template": "How many {colour} {object} do you see? (Ignore the other colours!)",
  "answer_type": "multiple_choice",
  "interaction": {
    "type": "tap_to_count",
    "target_formula": "N",
    "tap_targets": "target_objects",

{
  "id": "G1-ARITH-002",
  "grade": 1,
  "topic": "arithmetic_missing_numbers",
  "subtopic": "subtraction_within_10",
  "subskills": ["subtraction_basic", "counting_back"],
  "difficulty": 1,
  "tier": "warmup",
  "source_inspiration": "Academic cofounder L1 — subtract within 10 word problem",

  "pedagogy": "cpa_concrete",

  "stem_template": "{name} has {N} {object}. {pronoun_subject} gives {K} away. How many are left?",
  "answer_type": "multiple_choice",

  "interaction": {
    "type": "multiple_choice",
    "correct_option_index": null,
    "fallback_type": "multiple_choice"
  },

  "visual": {
    "type": "svg_generator",
    "generator": "remove_objects",
    "params": {"total": "{N}", "removed": "{K}", "object": "{object}"}
  },
  "visual_manifest": {
    "art_brief": "{N} {object} with {K} of them crossed out or being taken away. Bright cartoon style.",
    "alt_text": "{N} {object} with {K} being removed.",
    "style": "warm_cartoon",
    "layout_hint": "remove_group",
    "visual_type": "illustration"
  },

  "params": {
    "N":      {"range": [4, 10]},
    "K":      {"range": [1, 4], "constraint": "K<N"},
    "name":   {"pool": ["Aarav", "Priya", "Liam", "Sofia"]},
    "object": {"pool": ["apples", "marbles", "stickers"]}
  },
  "derived": {
    "pronoun_subject": "pronoun_from_name(name)"
  },

  "answer_formula": "N-K",
  "distractors": [
    {"formula": "N",   "label": "forgot_to_subtract"},
    {"formula": "K",   "label": "confused_subtrahend"},
    {"formula": "N+K", "label": "added_instead"}
  ],

  "misconceptions": [
    {
      "trigger_answer": "N",
      "diagnosis": "forgot_to_subtract",
      "feedback_child": "Remember, {name} gave {K} away! Take those away from {N}.",
      "step_down_path": ["G1-ARITH-002-S1", "G1-ARITH-002-S2"]
    },
    {
      "trigger_answer": "N+K",
      "diagnosis": "added_instead_of_subtracted",
      "feedback_child": "Oops! {name} gave some away, so we need fewer, not more. Try taking {K} away from {N}.",
      "step_down_path": ["G1-ARITH-002-S1", "G1-ARITH-002-S2"]
    },
    {
      "trigger_answer": "K",
      "diagnosis": "confused_subtrahend_for_answer",
      "feedback_child": "That's how many were given away, not how many are left. Start with {N} and count back {K}.",
      "step_down_path": ["G1-ARITH-002-S1"]
    }
  ],

  "socratic_feedback": {
    "on_correct": "Well done! {N} - {K} = {N-K}. {name} has {N-K} {object} left!",
    "on_incorrect": "Let's try again. Start with {N} and take away {K}.",
    "on_timeout": "Take your time! Hold up {N} fingers and put down {K}.",
    "encouragement_after_retry": "You're getting closer! Count backwards from {N}."
  },

  "curriculum_alignment": {
    "common_core": "1.OA.A.1",
    "cambridge_stage": 1,
    "cambridge_strand": "Number: Addition and Subtraction",
    "singapore_strand": "Whole Numbers"
  },

  "locale_context": {
    "IN":     {"objects": ["laddoos", "marbles", "stickers"]},
    "global": {"objects": ["apples", "marbles", "stickers"]}
  },

  "mastery_config": {
    "concept_id": "subtraction.within_10",
    "weight": 1.0
  },

  "tags": ["topic:arithmetic", "skill:subtraction", "cpa:concrete"],
  "est_time_seconds": 25,
  "version": 1,
  "author": "acad-v2",
  "status": "approved"
}
